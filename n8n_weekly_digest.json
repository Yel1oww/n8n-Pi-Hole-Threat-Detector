    {
      "parameters": {
        "method": "POST",
        "url": "http://[YOUR_INFLUXDB_IP]:8086/api/v2/query?org=[YOUR_ORG_NAME]",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/vnd.flux",
        "body": "from(bucket: \"[YOUR_BUCKET_NAME]\") |> range(start: -7d)\n|> filter(fn: (r) => r._measurement == \"domain_threats\" and r._field == \"blocked\" and r._value == true)\n|> group(columns: [\"client\"]) |> count() |> group()\n|> sort(columns: [\"_value\"], desc: true) |> limit(n: 5)",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/csv"
            }
          ]
