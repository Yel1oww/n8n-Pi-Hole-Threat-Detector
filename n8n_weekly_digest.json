      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        0
      ],
      "id": "6f43034b-d0bf-487f-b95e-479e8f355eae",
      "name": "Q Top Clients",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "function csvRows(node) {\n  let raw = $(node).first().json;\n  let t = typeof raw === \"string\" ? raw : (raw.data || raw.body || \"\");\n  if (typeof t !== \"string\") t = \"\";\n  const lines = t.split(\"\\n\").map(l => l.replace(/\\r$/, \"\")).filter(l => l && !l.startsWith(\"#\"));\n  if (!lines.length) return { header: [], rows: [] };\n  const header = lines.shift().split(\",\");\n  return { header, rows: lines.map(l => l.split(\",\")) };\n}\nfunction total(node) {\n  const { header, rows } = csvRows(node);\n  const vi = header.indexOf(\"_value\");\n  let sum = 0;\n  for (const r of rows) { const v = parseInt((r[vi] || \"\").trim(), 10); if (!isNaN(v)) sum += v; }\n  return sum;\n}\nfunction topClients() {\n  const { header, rows } = csvRows(\"Q Top Clients\");\n  const ci = header.indexOf(\"client\"), vi = header.indexOf(\"_value\");\n  const out = [];\n  for (const r of rows) {\n    if (ci >= 0 && vi >= 0 && r[ci] && r[ci].trim()) out.push(`  \u2022 ${r[ci].trim()}: ${(r[vi]||\"\").trim()}`);\n  }\n  return out.length ? out.join(\"\\n\") : \"  \u2022 none\";\n}\nconst scanned = total(\"Q Scanned\");\nconst blocked = total(\"Q Blocked\");\nconst msg = `Domains scanned: ${scanned}\\nDomains blocked: ${blocked}\\n\\nTop offending clients:\\n${topClients()}`;\nconst content = `\ud83d\udcc5 **Weekly DNS Digest** (last 7 days)\\n\\`\\`\\`\\n${msg}\\n\\`\\`\\``;\nreturn [{ json: { title: \"Weekly DNS Digest\", message: msg, content } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        0
      ],
