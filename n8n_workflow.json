    {
      "parameters": {
        "jsCode": "function esc(v) { return String(v).replace(/[ ,=]/g, \"\\\\$&\"); }\nfunction q(v) { return '\"' + String(v).replace(/\"/g, '\\\\\"') + '\"'; }\n// Safe reach-back: returns [] if a node didn't run this execution (avoids \"hasn't been executed\")\nfunction nodeItems(name) { try { return $(name).all(); } catch (e) { return []; } }\n\nreturn $input.all().map(item => {\n  const data = item.json;\n  const domain = data.domain || data.data?.id || data.indicator || \"unknown\";\n  if (domain === \"unknown\") return null;\n\n  const vt = data.data?.attributes?.last_analysis_stats?.malicious || 0;\n  const av = nodeItems(\"AlienVault Scan\").find(i =>\n    i.json.indicator === domain || i.json.domain === domain);\n  const pulses = av?.json?.pulse_info?.count || 0;\n  const en  = nodeItems(\"Local Enrich\").find(i => i.json.domain === domain)?.json || {};\n  const geo = nodeItems(\"GeoIP Normalize\").find(i => i.json.domain === domain)?.json || {};\n  const rd  = nodeItems(\"RDAP Normalize\").find(i => i.json.domain === domain)?.json || {};\n\n  const blocked = vt >= 5;\n  const verdict = blocked ? \"malicious\"\n    : (vt > 0 || pulses > 0 || en.dga_suspect || en.typosquat || en.punycode || rd.newly_registered)\n      ? \"suspicious\" : \"clean\";\n  const agreement = (vt > 0 && pulses > 0) ? \"both\"\n    : (vt > 0) ? \"vt_only\" : (pulses > 0) ? \"otx_only\" : \"neither\";\n\n  const tag = (k, v) => k + \"=\" + esc((v === undefined || v === null || v === \"\") ? \"unknown\" : v);\n  const tags = [\n    tag(\"domain\", domain),\n    tag(\"client\", en.client),\n    tag(\"country\", geo.country),\n    tag(\"verdict\", verdict),\n    tag(\"agreement\", agreement),\n  ].join(\",\");\n\n  const fields = [\n    \"pulses=\" + pulses + \"i\",\n    \"vt_detections=\" + vt + \"i\",\n    \"blocked=\" + (blocked ? \"true\" : \"false\"),\n    \"entropy=\" + (en.entropy ?? 0),\n    \"domain_age_days=\" + (rd.domain_age_days ?? -1) + \"i\",\n    \"dga_suspect=\" + (en.dga_suspect ? \"true\" : \"false\"),\n    \"typosquat=\" + (en.typosquat ? \"true\" : \"false\"),\n    \"punycode=\" + (en.punycode ? \"true\" : \"false\"),\n    \"newly_registered=\" + (rd.newly_registered ? \"true\" : \"false\"),\n    \"asn_org=\" + q(geo.asn_org || \"unknown\"),\n  ].join(\",\");\n\n  return { json: { line: `domain_threats,${tags} ${fields} ${Date.now()}` } };\n}).filter(Boolean);"
