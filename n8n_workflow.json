        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "raw",
        "body": "=domain_threats,domain={{ $json.domain.replace(' ', '') }} pulses={{ $json.pulses || 0 }}i,vt_detections={{ $json.vt_detections || 0 }}i,blocked={{ $json.blocked ? 'true' : 'false' }} {{ Date.now() }}",
        "options": {}
      },
