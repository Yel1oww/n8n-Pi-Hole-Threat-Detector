      "id": "0077e098-f119-4dce-9e6d-884aea8fb81e",
      "name": "Block Backup"
    },
    {
      "parameters": {
        "jsCode": "const d = $json.data || {};\nconst domain = d.id || \"unknown\";\nconst vt = d.attributes?.last_analysis_stats?.malicious || 0;\nconst geo = (()=>{try{return $(\"GeoIP Normalize\").all()}catch(e){return[]}})().find(i => i.json.domain === domain)?.json || {};\nconst loc = (()=>{try{return $(\"Filter Unique & Clean\").all()}catch(e){return[]}})().find(i => i.json.domain === domain)?.json || {};\nconst en  = (()=>{try{return $(\"Local Enrich\").all()}catch(e){return[]}})().find(i => i.json.domain === domain)?.json || {};\nconst rd  = (()=>{try{return $(\"RDAP Normalize\").all()}catch(e){return[]}})().find(i => i.json.domain === domain)?.json || {};\nconst flags = [];\nif (en.dga_suspect) flags.push(\"DGA\");\nif (en.typosquat) flags.push(\"typosquat->\" + en.typosquat_target);\nif (en.punycode) flags.push(\"punycode\");\nif (rd.newly_registered) flags.push(\"new-domain(\" + rd.domain_age_days + \"d)\");\nconst msg = `Domain: ${domain}\\nVT detections: ${vt}\\nClient: ${loc.client || \"?\"}\\n`\n  + `Origin: ${geo.country_name || \"?\"} (${geo.asn_org || \"?\"})\\n`\n  + `Signals: ${flags.length ? flags.join(\", \") : \"none\"}`;\nconst content = `\ud83d\udee1\ufe0f **Domain Blocked: ${domain}**\\n\\`\\`\\`\\n${msg}\\n\\`\\`\\``;\nreturn [{ json: { title: `Blocked ${domain}`, message: msg, content } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        -120
