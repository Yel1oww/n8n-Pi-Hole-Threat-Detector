      "typeVersion": 1.1,
      "position": [
        -3200,
        0
      ],
      "id": "fb56286e-850c-4458-ad91-8002bd1218d3",
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "url": "http://[YOUR_INFLUXDB_IP]:8086/api/v2/query?org=[YOUR_ORG_NAME]",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        },
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/csv"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/vnd.flux",
        "body": "=import \"date\"\nfrom(bucket: \"[YOUR_BUCKET_NAME]\")\n  |> range(start: date.truncate(t: now(), unit: 1d))\n  |> filter(fn: (r) => r._measurement == \"vt_usage\" and r._field == \"lookup\")\n  |> sum()",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -3000,
        0
      ],
      "id": "c68d7635-2aa8-4422-b469-d4f540d1c4da",
      "name": "VT Quota Check",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "\n// Parse the annotated CSV Flux result into a single running total for today.\nlet used = 0;\nconst raw = $input.first().json;\nlet text = typeof raw === \"string\" ? raw : (raw.data || raw.body || \"\");\nif (typeof text !== \"string\") text = JSON.stringify(text);\nfor (const line of text.split(\"\\n\")) {\n  const cols = line.split(\",\");\n  // annotated CSV: _value is the last numeric column on data rows (skip headers/comments)\n  if (cols.length > 3 && !line.startsWith(\"#\") && !line.includes(\"_value\")) {\n    const v = parseInt(cols[cols.length - 1].trim(), 10);\n    if (!isNaN(v)) used += v;\n  }\n}\nreturn [{ json: { usedToday: used, vtLimit: 480} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2800,
        0
      ],
      "id": "4d47fa9d-8e3c-484e-8b7b-9a15a4b88ace",
      "name": "VT Quota Parse"
    },
    {
      "parameters": {
        "url": "http://[YOUR_PIHOLE_PRIMARY_IP]/api/queries",
        "options": {},
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "from",
              "value": "={{ Math.floor(Date.now() / 1000) - 300 }}"
            },
            {
              "name": "length",
              "value": "5000"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -2600,
        0
      ],
      "id": "98a4e0db-9545-4545-a202-b6b01a01cc18",
      "name": "Get Pi-hole Logs"
    },
    {
      "parameters": {
        "fieldToSplitOut": "queries",
        "options": {}
      },
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [
        -2400,
        0
      ],
      "id": "02381001-3073-435e-99f4-38b465838005",
      "name": "Split Out"
    },
    {
      "parameters": {
        "jsCode": "// Build a domain -> {client counts} map so we keep attribution, not just the domain.\nconst counts = {};\nfor (const it of $input.all()) {\n  const q = it.json;\n  let d = (q.domain || \"\").toLowerCase().trim();\n  if (!d || d === \"unknown\" || d.includes(\".arpa\")) continue;\n  // Pi-hole v6 client is an object {ip,name}; fall back to string\n  let c = \"unknown\";\n  if (q.client && typeof q.client === \"object\") c = q.client.name || q.client.ip || \"unknown\";\n  else if (typeof q.client === \"string\") c = q.client;\n  counts[d] = counts[d] || {};\n  counts[d][c] = (counts[d][c] || 0) + 1;\n}\nreturn Object.keys(counts).map(d => {\n  const byClient = counts[d];\n  const primary = Object.keys(byClient).sort((a, b) => byClient[b] - byClient[a])[0];\n  return { json: { domain: d, client: primary, client_count: Object.keys(byClient).length } };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2200,
        0
      ],
      "id": "657926c5-a558-4648-ad3a-8022ccd959e7",
      "name": "Filter Unique & Clean"
    },
    {
      "parameters": {
        "jsCode": "// ---- edit this watchlist: your bank, employer, email + big brands you want protected ----\nconst WATCH = [\"google\",\"paypal\",\"microsoft\",\"apple\",\"amazon\",\"netflix\",\n  \"whatsapp\",\"instagram\",\"facebook\",\"outlook\",\"gmail\",\"binance\",\"coinbase\"];\n\nfunction shannon(s) {\n  const f = {}; for (const ch of s) f[ch] = (f[ch] || 0) + 1;\n  let h = 0; const n = s.length || 1;\n  for (const k in f) { const p = f[k] / n; h -= p * Math.log2(p); }\n  return h;\n}\nfunction lev(a, b) {\n  const m = a.length, n = b.length;\n  const dp = Array.from({length: m + 1}, (_, i) => [i, ...Array(n).fill(0)]);\n  for (let j = 0; j <= n; j++) dp[0][j] = j;\n  for (let i = 1; i <= m; i++) for (let j = 1; j <= n; j++)\n    dp[i][j] = Math.min(dp[i-1][j] + 1, dp[i][j-1] + 1,\n      dp[i-1][j-1] + (a[i-1] === b[j-1] ? 0 : 1));\n  return dp[m][n];\n}\n\nreturn $input.all().map(it => {\n  const domain = it.json.domain;\n  const labels = domain.split(\".\");\n  const sld = labels.length >= 2 ? labels[labels.length - 2] : domain; // registrable label\n  const bare = domain.replace(/\\./g, \"\");\n  const entropy = Math.round(shannon(bare) * 100) / 100;\n  const dga_suspect = entropy > 3.8 && bare.length > 12;\n  const punycode = labels.some(l => l.startsWith(\"xn--\"));\n  let typosquat = false, typosquat_target = \"\";\n  for (const w of WATCH) {\n    if (sld === w) { typosquat = false; break; }        // exact match = legit\n    const d = lev(sld, w);\n    if (d >= 1 && d <= 2 && Math.abs(sld.length - w.length) <= 2) {\n      typosquat = true; typosquat_target = w; break;\n    }\n  }\n  return { json: { ...it.json, entropy, dga_suspect, punycode, typosquat, typosquat_target } };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2000,
        0
      ],
      "id": "de30e975-f712-4d38-947e-53a8270e15a4",
      "name": "Local Enrich"
    },
    {
      "parameters": {
        "url": "http://[YOUR_INFLUXDB_IP]:8086/api/v2/query?org=[YOUR_ORG_NAME]",
