        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/vnd.flux",
        "body": "=from(bucket: \"[YOUR_BUCKET_NAME]\") |> range(start: -30d)\n|> filter(fn: (r) => r._measurement == \"domain_threats\" and r.domain == \"{{ $json.domain }}\")\n|> last()",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
