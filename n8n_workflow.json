    {
      "parameters": {
        "url": "=http://ip-api.com/json/{{ $('Filter Unique & Clean').item.json.domain }}?fields=status,country,countryCode,as,org,query",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -800,
        -120
      ],
      "id": "e8ce6427-7897-48ba-b9c5-af2b78bf9b24",
      "name": "GeoIP Lookup",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// GeoIP Lookup's INPUT item (from \"Has Pulse?\") still carries the AlienVault json,\n// whose `indicator` is the domain. Read the geo from this node's own input ($json),\n// and the domain from the item that entered GeoIP Lookup.\nconst j = $input.first().json || {};\nlet domain = j.query || \"unknown\";\ntry {\n  const src = $(\"Has Pulse?\").first().json;\n  domain = src.indicator || src.domain || domain;\n} catch (e) {}\nlet asn = \"\", asn_org = j.org || \"\";\nif (j.as) { const m = j.as.match(/^(AS\\d+)\\s*(.*)$/); if (m) { asn = m[1]; asn_org = asn_org || m[2]; } }\nreturn [{ json: { domain, country: j.countryCode || \"??\", country_name: j.country || \"Unknown\",\n  asn, asn_org: (asn_org || \"unknown\") } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -600,
        -120
      ],
      "id": "061db744-7c63-47b7-8d80-0ad16238c708",
      "name": "GeoIP Normalize"
    },
    {
      "parameters": {
        "url": "=https://rdap.org/domain/{{ $json.domain }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -800,
        120
      ],
      "id": "59ca9831-8a62-4ad2-9826-9665e77518ec",
      "name": "RDAP Lookup",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const j = $input.first().json || {};\nlet domain = \"unknown\";\ntry { domain = $(\"GeoIP Normalize\").first().json.domain || \"unknown\"; } catch (e) {}\nif (domain === \"unknown\") domain = j.ldhName ? String(j.ldhName).toLowerCase() : \"unknown\";\nlet age = -1, newly = false;\ntry {\n  let events = j.events;\n  if (!events && typeof (j.data || j.body) === \"string\") {\n    try { const p = JSON.parse(j.data || j.body); events = p.events; } catch (e) {}\n  }\n  events = events || [];\n  let ev = events.find(e => e.eventAction === \"registration\");\n  if (!ev && events.length) {\n    ev = events.slice().sort((a, b) => new Date(a.eventDate) - new Date(b.eventDate))[0];\n  }\n  if (ev && ev.eventDate) {\n    const t = new Date(ev.eventDate).getTime();\n    if (!isNaN(t)) { age = Math.floor((Date.now() - t) / 86400000); newly = age >= 0 && age < 30; }\n  }\n} catch (e) {}\nreturn [{ json: { domain, domain_age_days: age, newly_registered: newly } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -600,
