    },
    {
      "parameters": {
        "jsCode": "const domains = $input.all().map(i => i.json.domain).filter(d => d);\nconst unique = [...new Set(domains)];\n\nreturn unique\n  .map(d => d.toLowerCase().trim())\n  .filter(d => d !== \"unknown\" && d !== \"\" && !d.includes('.arpa'))\n  .map(d => ({ json: { domain: d } }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1952,
